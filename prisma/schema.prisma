generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  status      String      @default("Planning")
  githubUrl   String?
  tags        String?
  startDate   DateTime?
  targetDate  DateTime?
  features    Feature[]
  notes       Note[]
  wireframes  Wireframe[]
  tasks       Task[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Feature {
  id            String    @id @default(cuid())
  title         String
  description   String?
  status        String    @default("Backlog")
  priority      String    @default("Medium")
  labels        String?
  order         Int       @default(0)
  featureNumber Int       @default(0)
  dueDate       DateTime?
  tasks         Task[]
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Task {
  id        String    @id @default(cuid())
  title     String
  done      Boolean   @default(false)
  priority  String    @default("Medium")
  dueDate   DateTime?
  featureId String?
  feature   Feature?  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  template  String?
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wireframe {
  id        String   @id @default(cuid())
  name      String
  data      String   @default("{}")
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
